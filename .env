VITE_WALLETCONNECT_PROJECT_ID=f1078fa0e775ada7fbc944a8fb1417fc

# Backend API base URL — used by every fetch() to /escrow/register,
# /demo/register, /escrow/meta, /demo/meta. Public; not a secret.
# Override locally via .env.local if you want to point at a dev backend.
VITE_API_URL=https://moneycrow-backend-production.up.railway.app

# Alchemy API key — when set, the WalletSnapshot panel uses Alchemy's
# alchemy_getTokenBalances + getTokenMetadata to show EVERY ERC-20 the
# wallet holds on Base and Polygon, not just the curated short list.
# Free tier from alchemy.com is plenty for this use case.
# Leave unset to fall back to the curated token list.
# Production value lives in Vercel env vars (set Project → Settings →
# Environment Variables → VITE_ALCHEMY_API_KEY for all environments).
# VITE_ALCHEMY_API_KEY=
